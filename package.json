{
  "name": "ancients",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "ANCIENTS — a Dota 2 x Pokemon open-world RPG in the browser. Data-driven, procedural fallback, Phase 5 asset pipeline.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:perf": "vitest run src/test/perf-budget.test.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "build:assets": "node scripts/assets/build_assets.mjs",
    "assets:manifest": "node scripts/assets/build_assets.mjs --manifest --report",
    "assets:check": "node scripts/assets/build_assets.mjs --manifest --report --check-budgets"
  },
  "dependencies": {
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.0",
    "@gltf-transform/extensions": "^4.4.0",
    "@gltf-transform/functions": "^4.4.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "@types/three": "^0.184.1",
    "meshoptimizer": "^1.1.1",
    "sharp": "^0.35.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
